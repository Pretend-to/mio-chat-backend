{
  "name": "mio-chat",
  "type": "module",
  "version": "0.0.1",
  "description": "AI-Powered chat platform,support ONEBOT v11",
  "main": "index.js",
  "scripts": {
    "dev": "node --watch app.js",
    "start": "pm2 start ./config/pm2.json",
    "init": "node scripts/setup.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "node test",
    "format": "prettier --write .",
    "docker:build": "docker build -t mio-chat-backend .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "gpt"
  ],
  "author": "mio",
  "license": "ISC",
  "devDependencies": {
    "oxlint": "^1.57.0",
    "prettier": "^3.8.1",
    "prisma": "^5.22.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/client": "^5.22.0",
    "api": "^6.1.3",
    "axios": "^1.13.6",
    "chokidar": "^4.0.3",
    "eventsource-parser": "^3.0.6",
    "express": "^4.22.1",
    "express-static-gzip": "^2.2.0",
    "file-type": "^21.3.4",
    "form-data": "^4.0.5",
    "formdata-node": "^6.0.3",
    "google-auth-library": "^9.15.1",
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.23",
    "multer": "^2.1.1",
    "nan": "^2.26.2",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "officeparser": "^5.2.2",
    "openai": "^6.32.0",
    "puppeteer": "^23.11.1",
    "socket.io": "^4.8.3",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "workspaces": [
    "plugins/*"
  ],
  "pnpm": {
    "overrides": {
      "underscore": ">=1.13.8",
      "file-type": "^21.3.4"
    }
  }
}