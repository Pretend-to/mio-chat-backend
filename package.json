{
  "name": "mio-chat",
  "type": "module",
  "version": "0.0.1",
  "description": "AI-Powered chat platform,support ONEBOT v11",
  "main": "index.js",
  "scripts": {
    "dev": "node --watch app.js",
    "start": "pm2 start ./config/pm2.json",
    "init": "node scripts/setup.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "node test",
    "format": "prettier --write .",
    "docker:build": "docker build -t mio-chat-backend .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "gpt"
  ],
  "author": "mio",
  "license": "ISC",
  "devDependencies": {
    "oxlint": "^1.33.0",
    "prettier": "^3.6.2",
    "prisma": "^5.22.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@prisma/client": "^5.22.0",
    "api": "^6.1.1",
    "axios": "^1.6.7",
    "chokidar": "^4.0.3",
    "eventsource-parser": "^3.0.0",
    "express": "^4.18.2",
    "express-static-gzip": "^2.1.0",
    "file-type": "^20.1.0",
    "form-data": "^4.0.2",
    "formdata-node": "^6.0.3",
    "google-auth-library": "^9.15.1",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "multer": "2.0.1",
    "nan": "^2.18.0",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "officeparser": "^5.1.1",
    "openai": "^6.10.0",
    "puppeteer": "^23.1.1",
    "socket.io": "^4.8.1",
    "ws": "^8.18.0",
    "zod": "^4.1.13"
  },
  "workspaces": [
    "plugins/*"
  ]
}