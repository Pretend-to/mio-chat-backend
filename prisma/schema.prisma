// Prisma schema file for Mio-Chat SQLite migration

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

// 预设表
model Preset {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  type        String   @default("custom") // 'built-in' | 'custom'
  category    String   @default("common") // 'common' | 'recommended' | 'hidden'
  history     String // JSON 格式存储对话历史
  opening     String   @default("")
  textwrapper String   @default("")
  tools       String   @default("[]") // JSON 格式存储工具列表
  provider    String   @default("") // LLM 渠道名（displayName），空则使用系统默认
  model       String   @default("") // 模型名，空则使用渠道默认
  recommended Boolean  @default(false)
  hidden      Boolean  @default(false)
  avatar      String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@index([type])
  @@index([category])
  @@map("presets")
}

// 插件配置表
model PluginConfig {
  id         Int      @id @default(autoincrement())
  pluginName String   @unique @map("plugin_name")
  configData String   @map("config_data") // JSON 格式存储配置
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([pluginName])
  @@index([enabled])
  @@map("plugin_configs")
}

// 系统配置表
model SystemSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String // JSON 格式存储复杂配置
  category    String   @default("general") // 'general' | 'server' | 'web' | 'onebot' | 'llm'
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@index([category])
  @@map("system_settings")
}

// LLM适配器配置表
model LLMAdapter {
  id           Int      @id @default(autoincrement())
  adapterType  String   @map("adapter_type") // 'openai' | 'gemini' | 'vertex' | 'deepseek'
  instanceName String   @map("instance_name") // 实例名称，同类型可有多个实例
  configData   String   @map("config_data") // JSON 格式存储适配器配置
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([adapterType, instanceName])
  @@index([adapterType])
  @@index([enabled])
  @@map("llm_adapters")
}

// 模型所有者配置表
model ModelOwner {
  id        Int      @id @default(autoincrement())
  owner     String
  keywords  String // JSON 数组格式存储关键词
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([owner])
  @@map("model_owners")
}

// 日志配置表
model LogConfig {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  bufferSize    Int      @default(1000) @map("buffer_size")
  flushInterval Int      @default(1000) @map("flush_interval")
  sources       String   @default("[]") // JSON 格式存储日志源
  filters       String   @default("{}") // JSON 格式存储过滤器
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@map("log_configs")
}

// 日志统计表
model LogStat {
  id        Int      @id @default(autoincrement())
  date      DateTime
  level     String
  count     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([date, level])
  @@index([date])
  @@index([level])
  @@map("log_stats")
}

// 定时任务表
model Task {
  id           String    @id // 任务唯一 ID (taskId)
  name         String?
  cron         String // Cron 表达式，或者 "once"
  runAt        DateTime? @map("run_at") // 指定运行时间（用于一次性延迟任务）
  preset       String // 绑定的 Agent 预设名
  systemPrompt String?   @map("system_prompt") // 可选的系统提示词覆盖
  tools        String?   @default("[]") // 可选的工具列表覆盖 (JSON)
  triggerPrompt String?   @default("") @map("prompt") // 任务唤起/触发提示词
  userId       String?   @map("user_id") // 结果推送的目标用户
  contactorId  String?   @map("contactor_id") // 前端对话框 ID
  provider     String? // LLM 渠道 (快照)
  model        String? // 模型名称 (快照)
  status       String    @default("active") // 'active' | 'disabled' | 'finished'
  history      String?   @default("[]") // 存储任务运行的连续前端格式对话历史
  shWhitelist  String?   @default("")   // 自定义命令白名单，换行或逗号分隔
  lastRunAt    DateTime? @map("last_run_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  executions   TaskExecution[]

  @@index([userId])
  @@index([status])
  @@map("tasks")
}

// 任务执行记录表（每次定时触发对应一条）
model TaskExecution {
  id                Int       @id @default(autoincrement())
  taskId            String    @map("task_id")
  round             Int       @default(1)
  userId            String?   @map("user_id")
  contactorId       String?   @map("contactor_id")
  provider          String?
  model             String?
  triggerPrompt     String?   @map("trigger_prompt")
  inputMessages     String    @map("input_messages") // JSON: 发送给 LLM 的完整 messages 数组
  outputChunks      String    @default("[]") @map("output_chunks") // JSON: 原始 streamCache chunks 全量
  finalAssistantMsg String?   @map("final_assistant_msg") // JSON: 组装后的 assistant 消息
  status            String    @default("running") // running | completed | failed
  startedAt         DateTime  @default(now()) @map("started_at")
  finishedAt        DateTime? @map("finished_at")
  errorMessage      String?   @map("error_message")

              task              Task      @relation(fields: [taskId], references: [id])

  @@index([taskId])
  @@index([taskId, round])
  @@index([status])
  @@map("task_executions")
}

// LLM 调用审计日志表
model LLMCallLog {
  id               Int      @id @default(autoincrement())
  requestId        String   @map("request_id") // 关联事件请求 ID (e.requestId)
  userId           String?  @map("user_id") // 触发调用的用户 ID (e.user?.id)
  userIp           String?  @map("user_ip") // 触发调用的 IP 地址 (e.user?.ip)
  contactorId      String?  @map("contactor_id") // 触发会话的窗口 ID (e.body?.contactorId)
  presetName       String?  @map("preset_name") // 使用的 Agent 预设名称 (e.body?.settings?.presetSettings?.name)
  sessionTitle     String?  @map("session_title") // 关联会话的主题/第一条输入
  provider         String // 适配器渠道 (openai, deepseek, gemini, vertex 等)
  model            String // 调用的具体模型 (如 deepseek-chat, gpt-5.4-nano 等)
  isStream         Boolean  @default(true) @map("is_stream") // 是否流式请求
  trafficType      String?  @map("traffic_type") // 计费流量类型 (如 Gemini: ON_DEMAND)
  promptTokens     Int      @default(0) @map("prompt_tokens") // 输入 Token 数
  candidatesTokens Int      @default(0) @map("candidates_tokens") // 输出 Token 数
  thinkingTokens   Int      @default(0) @map("thinking_tokens") // 深度思考 Token 数
  toolsCalled      String?  @default("[]") @map("tools_called") // JSON 数组，记录调用的多个工具名称 (如 ["memory_query", "web_search"])
  toolDetails      String?  @default("[]") @map("tool_details") // JSON 数组，记录调用的多个工具详细信息 { name, arguments, output }
  cacheHitTokens   Int      @default(0) @map("cache_hit_tokens") // 缓存命中 Token 数
  cacheMissTokens  Int      @default(0) @map("cache_miss_tokens") // 缓存未命中 Token 数
  totalTokens      Int      @default(0) @map("total_tokens") // 总 Token 数
  latency          Int // 总耗时/延迟 (单位: ms)
  ttft             Int? // 首字延迟 (Time-To-First-Token, 单位: ms)，非流式则为 null
  tps              Float? // 响应速度 (Tokens Per Second, 仅针对 candidates)
  status           String   @default("SUCCESS") // 状态: SUCCESS (成功) | FAILED (异常失败) | ABORTED (用户中止)
  errorMessage     String?  @map("error_message") // 失败异常时的错误堆栈/原因
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([requestId])
  @@index([userId])
  @@index([userIp])
  @@index([contactorId])
  @@index([provider])
  @@index([model])
  @@index([status])
  @@index([createdAt])
  @@map("llm_call_logs")
}
